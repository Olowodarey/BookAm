# PostgreSQL connection string used by Prisma
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/bookam?schema=public"

# Secret used to sign admin JWTs — set a long random value in real environments
JWT_SECRET="change-me-in-production"

# Backend HTTP port (frontend expects 4000 by default)
PORT=4000

# Comma-separated origins allowed by CORS
CORS_ORIGIN="http://localhost:3000"

# Seed script: credentials for the initial platform admin account
SEED_ADMIN_PHONE="+2348000000001"
SEED_ADMIN_PASSWORD="admin1234"

# Base URL of the frontend, used to build shareable circle invite links
FRONTEND_URL="http://localhost:3000"

# Seed script: password given to the demo coordinator (+2348011111111)
SEED_COORDINATOR_PASSWORD="alajo1234"

# Seed script: password given to the demo member accounts (e.g. +2348033333333)
SEED_MEMBER_PASSWORD="member1234"

# Seed script: dedicated test accounts (phone + password)
SEED_TEST_COLLECTOR_PHONE="+2348090000001"
SEED_TEST_COLLECTOR_PASSWORD="collector5678"
SEED_TEST_MEMBER_PHONE="+2348090000002"
SEED_TEST_MEMBER_PASSWORD="contributor5678"
