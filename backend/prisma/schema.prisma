generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  MEMBER
  COORDINATOR
  ADMIN
}

enum UserStatus {
  ACTIVE
  SUSPENDED
}

enum ApplicationStatus {
  PENDING
  APPROVED
  REJECTED
}

enum BillingInterval {
  MONTHLY
  QUARTERLY
  YEARLY
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum CircleFrequency {
  DAILY
  WEEKLY
  MONTHLY
}

enum CircleStatus {
  ACTIVE
  COMPLETED
  PAUSED
}

enum MembershipStatus {
  // Coordinator added this account by email; awaiting the member's acceptance.
  INVITED
  // Member asked to join via the invite link; awaiting the coordinator's approval.
  REQUESTED
  // Accepted/approved — in the rotation with a position.
  ACTIVE
  REMOVED
}

enum CycleStatus {
  OPEN
  COMPLETED
}

enum ContributionStatus {
  AWAITING
  PENDING_REVIEW
  PAID
  REJECTED
}

enum PayoutStatus {
  PENDING
  COMPLETED
}

enum AppealStatus {
  OPEN
  APPROVED
  REJECTED
  WITHDRAWN
}

enum VoteValue {
  SUPPORT
  OPPOSE
}

model User {
  id                String     @id @default(cuid())
  // Email is BookAm's primary identity — one email, one account. Set by
  // email+password sign-up or Google sign-in, which link on the same email.
  email             String     @unique
  name              String
  // Password sign-in; Google-only users may not have one.
  passwordHash      String?
  // Set once the email is confirmed (via emailed OTP, or trusted from Google
  // which always returns a verified email).
  emailVerifiedAt   DateTime?
  // Google sign-in credential.
  googleId          String?    @unique
  // Optional WhatsApp/phone number, verified in-app later. Verifying it claims
  // any circle memberships a coordinator already added by that number — but a
  // phone is no longer required to have an account.
  phone             String?    @unique
  phoneVerifiedAt   DateTime?
  // Profile/settings — records only, so circles know where to send money
  // OUTSIDE BookAm. Never used to move funds in-app.
  altPhone          String?
  bankName          String?
  bankAccountNumber String?
  bankAccountName   String?
  role              Role       @default(MEMBER)
  status            UserStatus @default(ACTIVE)
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt

  applications          CollectorApplication[] @relation("Applicant")
  reviewedApplications  CollectorApplication[] @relation("Reviewer")
  subscriptions         Subscription[]
  coordinatedCircles    Circle[]               @relation("Coordinator")
  memberships           Membership[]           @relation("MemberUser")
  reviewedContributions Contribution[]         @relation("ContributionReviewer")
  decidedAppeals        Appeal[]               @relation("AppealDecider")
  contributionReceipts  ContributionReceipt[]  @relation("ContributionReceiptUploader")
  payoutReceipts        PayoutReceipt[]        @relation("PayoutReceiptUploader")
}

model CollectorApplication {
  id     String            @id @default(cuid())
  status ApplicationStatus @default(PENDING)
  // Free-text reason the applicant submitted with their request.
  note   String?

  applicant   User   @relation("Applicant", fields: [applicantId], references: [id])
  applicantId String

  reviewNote   String?
  reviewedBy   User?     @relation("Reviewer", fields: [reviewedById], references: [id])
  reviewedById String?
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
  @@index([applicantId])
}

model SubscriptionPlan {
  id         String          @id @default(cuid())
  name       String          @unique
  // BookAm's own SaaS fee, charged off-platform via Paystack.
  // NOT member ajo money — BookAm never holds contributions.
  priceNaira Int
  interval   BillingInterval @default(MONTHLY)
  maxCircles Int?
  features   String[]
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  subscriptions Subscription[]
}

model Subscription {
  id          String             @id @default(cuid())
  user        User               @relation(fields: [userId], references: [id])
  userId      String
  plan        SubscriptionPlan   @relation(fields: [planId], references: [id])
  planId      String
  status      SubscriptionStatus @default(ACTIVE)
  periodStart DateTime
  periodEnd   DateTime
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt

  @@index([userId])
  @@index([status])
}

model Circle {
  id                      String          @id @default(cuid())
  name                    String
  contributionAmountNaira Int
  frequency               CircleFrequency
  status                  CircleStatus    @default(ACTIVE)
  // Planned rotation size (number of member slots the coordinator set up).
  memberTarget            Int             @default(0)
  // Random token for the shareable "join this circle" link. Null = link off.
  inviteToken             String?         @unique
  coordinator             User            @relation("Coordinator", fields: [coordinatorId], references: [id])
  coordinatorId           String
  createdAt               DateTime        @default(now())
  updatedAt               DateTime        @updatedAt

  memberships Membership[]
  cycles      Cycle[]
  appeals     Appeal[]

  @@index([coordinatorId])
}

model Membership {
  id        String           @id @default(cuid())
  circle    Circle           @relation(fields: [circleId], references: [id])
  circleId  String
  // Every member is a real BookAm account (invited by email or via the link),
  // so userId is always set now. name/phone are copied from their profile.
  user      User?            @relation("MemberUser", fields: [userId], references: [id])
  userId    String?
  name      String
  phone     String?
  // 1-based slot in the payout rotation, assigned when the membership becomes
  // ACTIVE. Pending (INVITED/REQUESTED) rows sit at 0 until then. Uniqueness
  // among ACTIVE members is enforced in the service layer.
  position  Int              @default(0)
  status    MembershipStatus @default(INVITED)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  contributions    Contribution[]
  payouts          Payout[]
  collectingCycles Cycle[]        @relation("CycleCollector")
  appeals          Appeal[]
  appealVotes      AppealVote[]

  @@index([circleId])
  @@index([userId])
}

model Cycle {
  id          String      @id @default(cuid())
  circle      Circle      @relation(fields: [circleId], references: [id])
  circleId    String
  // 1-based period number within the circle (cycle 3 = third payout turn).
  index       Int
  status      CycleStatus @default(OPEN)
  // Whose turn it is to collect the pot this cycle.
  collector   Membership? @relation("CycleCollector", fields: [collectorId], references: [id])
  collectorId String?
  startedAt   DateTime    @default(now())
  completedAt DateTime?

  contributions Contribution[]
  payout        Payout?

  @@unique([circleId, index])
  @@index([circleId, status])
}

model Contribution {
  id              String             @id @default(cuid())
  membership      Membership         @relation(fields: [membershipId], references: [id])
  membershipId    String
  cycle           Cycle              @relation(fields: [cycleId], references: [id])
  cycleId         String
  // Record of what the member paid outside BookAm — never money BookAm holds.
  amountNaira     Int
  status          ContributionStatus @default(AWAITING)
  // Reference to the uploaded proof-of-payment file (image/PDF), e.g. "/uploads/x.png".
  receiptFileUrl  String?
  rejectionReason String?
  reviewedBy      User?              @relation("ContributionReviewer", fields: [reviewedById], references: [id])
  reviewedById    String?
  reviewedAt      DateTime?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  // Installment ledger — a contribution may be paid bit by bit, each part with
  // its own receipt. receiptFileUrl above mirrors the latest one for display.
  receipts        ContributionReceipt[]

  @@unique([membershipId, cycleId])
  @@index([cycleId, status])
}

model Payout {
  id             String       @id @default(cuid())
  cycle          Cycle        @relation(fields: [cycleId], references: [id])
  cycleId        String       @unique
  collector      Membership   @relation(fields: [collectorId], references: [id])
  collectorId    String
  // Computed sum of PAID contributions at completion time — a label on a
  // record, not a balance BookAm controls or disburses.
  amountNaira    Int
  status         PayoutStatus @default(PENDING)
  // Proof the coordinator sent the pot to the collector (outside BookAm).
  // Mirrors the latest receipt below for display; the full ledger is `receipts`.
  receiptFileUrl String?
  completedAt    DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  // A payout may also be sent bit by bit, each part with its own receipt.
  receipts       PayoutReceipt[]

  @@index([collectorId])
}

/**
 * One proof-of-payment toward a contribution. Contributions can be paid in
 * installments, so each part is recorded here with its amount and receipt.
 * Records only — BookAm never holds or moves the money.
 */
model ContributionReceipt {
  id             String       @id @default(cuid())
  contribution   Contribution @relation(fields: [contributionId], references: [id], onDelete: Cascade)
  contributionId String
  amountNaira    Int
  receiptFileUrl String
  // Who uploaded it (the member themselves, or the coordinator on their behalf).
  uploadedBy     User?        @relation("ContributionReceiptUploader", fields: [uploadedById], references: [id])
  uploadedById   String?
  note           String?
  createdAt      DateTime     @default(now())

  @@index([contributionId])
}

/** One proof-of-payment toward a payout (the coordinator paying the collector). */
model PayoutReceipt {
  id             String   @id @default(cuid())
  payout         Payout   @relation(fields: [payoutId], references: [id], onDelete: Cascade)
  payoutId       String
  amountNaira    Int
  receiptFileUrl String
  uploadedBy     User?    @relation("PayoutReceiptUploader", fields: [uploadedById], references: [id])
  uploadedById   String?
  note           String?
  createdAt      DateTime @default(now())

  @@index([payoutId])
}

// One-time codes for phone verification. Codes are stored hashed and the
// send itself happens outside the DB (see OtpService — WhatsApp/SMS TODO).
model PhoneOtp {
  id         String    @id @default(cuid())
  phone      String
  codeHash   String
  expiresAt  DateTime
  // Wrong guesses; the code locks after too many.
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([phone, createdAt])
}

model EmailOtp {
  id         String    @id @default(cuid())
  email      String
  codeHash   String
  expiresAt  DateTime
  // Wrong guesses; the code locks after too many.
  attempts   Int       @default(0)
  consumedAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([email, createdAt])
}

// A member's request to be considered to collect next. Voting is advisory;
// the coordinator makes the final call and the whole trail stays visible to
// every member of the circle.
model Appeal {
  id          String       @id @default(cuid())
  circle      Circle       @relation(fields: [circleId], references: [id])
  circleId    String
  appellant   Membership   @relation(fields: [appellantId], references: [id])
  appellantId String
  // Why they want to collect next (emergency, school fees, medical, …).
  reason      String
  status      AppealStatus @default(OPEN)
  // Coordinator decision trail — recorded and shown to all members.
  decidedBy   User?        @relation("AppealDecider", fields: [decidedById], references: [id])
  decidedById String?
  decidedAt   DateTime?
  outcomeNote String?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  votes AppealVote[]

  @@index([circleId, status])
  @@index([appellantId])
}

model AppealVote {
  id        String     @id @default(cuid())
  appeal    Appeal     @relation(fields: [appealId], references: [id])
  appealId  String
  voter     Membership @relation(fields: [voterId], references: [id])
  voterId   String
  value     VoteValue
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  // One vote per member per appeal (changeable until the appeal is decided).
  @@unique([appealId, voterId])
}
